# ═══════════════════════════════════════════════════════════════════
#  ProjectGenie Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_SUPABASE_HOST:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres"

# JWT secret for authentication tokens
JWT_SECRET="your_strong_secret_key_here"

# Server port (default: 3000)
PORT=3000

# ─── SMTP Email Config (optional, uses Ethereal for dev) ─────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
